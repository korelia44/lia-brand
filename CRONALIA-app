// ─── スコアリング ───
function calcResult(answers) {
  const osCounts = {}, attachCounts = {}, defenseCounts = {};
  answers.forEach(({ choice }) => {
    if (choice.os)         osCounts[choice.os]         = (osCounts[choice.os]         || 0) + 1;
    if (choice.attachment) attachCounts[choice.attachment] = (attachCounts[choice.attachment] || 0) + 1;
    if (choice.defense)    defenseCounts[choice.defense]   = (defenseCounts[choice.defense]   || 0) + 1;
  });

  const topOS      = Object.entries(osCounts).sort((a, b) => b[1] - a[1]);
  const topAttach  = Object.entries(attachCounts).sort((a, b) => b[1] - a[1]);
  const topDefense = Object.entries(defenseCounts).sort((a, b) => b[1] - a[1]);

  const mainOSKey  = topOS[0]?.[0] || "自律";
  const subOSKey   = topOS[1]?.[0] || null;
  const attachKey  = topAttach[0]?.[0] || "安全";
  const defenseKey = topDefense[0]?.[0] || "知性化";

  const cockpitMap   = { 自律:90, 救済:65, 自己加速:60, 過剰観測:45, 追跡:40, 外部参照:35, 距離調整:50, 判断停止:20 };
  const cockpitScore = cockpitMap[mainOSKey] || 50;
  const cockpitStatus = cockpitScore >= 70 ? "HIGH" : cockpitScore >= 45 ? "MID" : "LOW";
  const attachScore  = { 安全:88, 回避:50, 不安:38, 恐れ回避:25 }[attachKey] || 50;
  const intensity    = Math.min(75 + (topOS[0]?.[1] || 1) * 4, 96);

  const osLabel = { 自律:"自律型", 救済:"救済型", 自己加速:"自己加速型", 過剰観測:"過剰観測型", 追跡:"追跡型", 外部参照:"外部参照型", 距離調整:"距離調整型", 判断停止:"判断停止型" };
  const attachLabel = { 安全:"安全型", 不安:"不安型", 回避:"回避型", 恐れ回避:"恐れ回避型" };

  // 構造マップの説明文（2〜3行）
  const osDesc = {
    自律:     "自分の感覚を起点に動ける状態。\n判断を外に預けず、自分の中に軸を持っている。",
    救済:     "誰かのために動くことで、自分の居場所を確認する構造。\n相手が安定すると、自分も落ち着く。",
    自己加速: "「頑張れば変わる」という信念で動いている。\n努力がアイデンティティと結びついていることが多い。",
    過剰観測: "相手や状況の変化に敏感に反応する。\n常にアンテナが立っていて、疲れていないか確認したい。",
    追跡:     "距離ができると、縮めようと動き出す構造。\n「離れること＝終わり」と感じやすいパターン。",
    外部参照: "判断の基準が自分の外にある。\n占い・評価・他者の意見が、行動の起点になりやすい。",
    距離調整: "感情を整えてから動く。慎重さの裏に、\n近づくことへの警戒が働いていることがある。",
    判断停止: "迷いや不安で、行動の起点が止まっている状態。\n選べないのは、失敗を避けようとしているサインかもしれない。",
  };
  const attachDesc = {
    安全:     "親密さを自然に受け入れられる。\n距離の変化に過剰反応せず、関係を安定させやすい。",
    不安:     "「見捨てられるかも」という感覚が動きやすい。\n相手の反応に過敏になったり、確認行動が出やすい。",
    回避:     "深い親密さに、無意識に距離を置こうとする。\n自立を大切にする一方で、孤独になりやすい。",
    恐れ回避: "近づきたいのに、深く怖い。\n引き寄せては離すというパターンが生まれやすい。",
  };
  const cockpitDesc = {
    HIGH: "判断の主語が「自分」にある状態。\n外の出来事に揺さぶられにくく、選択の軸を保ちやすい。",
    MID:  "自分と外の間で判断軸が揺れている。\n場面や相手によって、操縦席が変わることがある。",
    LOW:  "判断の主語が外にある、または止まっている状態。\n「自分が決めた」という感覚を取り戻すことが、最初の一歩になる。",
  };
  const defenseDesc = {
    知性化: "感情を封じるために、分析や言語化で覆っている。\n感じる代わりに考えてしまうパターン。CRONA'LIA読者に最も多い。",
    合理化: "都合の悪い現実に、納得できる物語を後付けする。\n「仕方なかった」と処理することで、感情を避けている。",
    投影:   "自分の内側にある感情を、他者の中に見てしまう。\n「世界が敵に見える」時、自分の何かが映っていることがある。",
    解離:   "自分の状況を、他人事のように眺める状態。\n感情から切り離されて、ぼんやりしている感覚。",
    抑圧:   "不快な感情や記憶を、無意識に押し込んでいる。\nある日突然、理由もなく落ち込む時の構造。",
    昇華:   "感情や衝動を、創造的な活動に転換している。\n感じていないのではなく、別の形で動かしている。",
    否認:   "現実をそのまま受け取ることを、無意識に避けている。\n「大丈夫」と言い続けることで、感情が蓄積する。",
    同一化: "他者の価値観や人格を無意識に取り込んで生きている。\n「借り物の自分」で動いている感覚。",
  };
  const observationMap = {
    自律:     "あなたの判断軸は、比較的自分の中に根ざしています。それでも「本当にこれでいいのか」という問いが浮かぶ時、その問い自体があなたの構造を教えてくれています。",
    過剰観測: "あなたは相手や状況をよく見ています。ただ、その視線が自分に向いた時、同じ精度で「今の自分の状態」を見ることができていますか？",
    追跡:     "距離ができることへの反応が早い構造があります。近づこうとする動きの裏に、何が怖いのかを見てみると、パターンの輪郭が見えてきます。",
    救済:     "誰かの問題に動かされやすい構造があります。相手を助けることと、自分が必要とされることが、どこかで繋がっていないか観てみてください。",
    距離調整: "感情を整理してから動く。その慎重さの裏に、近づくことへの警戒が働いていることがあります。壁は守るためにあるけれど、自分も閉じ込めていないかを確認してみてください。",
    自己加速: "「頑張れば変わる」という信念が強い。努力は武器になりますが、止まれない構造になっていないか確認してみてください。動かないことも、選択のひとつです。",
    外部参照: "判断の基準が外にある時、答えを探す先をずらしてみてください。誰かが「正解」を持っているわけではなく、あなたの中にすでにある感覚が、いつも少し遅れて届いています。",
    判断停止: "今、動けない状態にある。それは能力の問題ではなく、情報が多すぎるか、失敗することへの警戒が働いているかもしれません。大きな選択より、今日できる一番小さな選択から始めてみてください。",
  };
  const nextStepMap = {
    自律:     "「なぜそう感じるのか」をもう一段掘り下げると、思考のパターンが見えてきます。",
    過剰観測: "相手を見る時間の一部を、自分の身体の状態を確認することに使ってみてください。",
    追跡:     "「連絡したい」と思った瞬間に、一度10分だけ待ってみる。その間に何が起きるかを観てみてください。",
    救済:     "「頼まれていないのに動いている」場面に気づくことが、最初のステップです。",
    距離調整: "壁を作る前に、「今自分は何を守ろうとしているか」を一度だけ確認してみてください。",
    自己加速: "「何もしない時間」を意図的に作ることが、構造をずらす入口になります。",
    外部参照: "「もし誰も見ていなかったら、どうしたいか」を問いとして持ってみてください。",
    判断停止: "大きな決断を保留にして、今日できる一番小さな選択を一つだけしてみてください。",
  };

  return {
    mainOSKey, mainOS: osLabel[mainOSKey] || mainOSKey, mainOSDesc: osDesc[mainOSKey] || "",
    subOS: subOSKey ? osLabel[subOSKey] : null,
    attachType: attachLabel[attachKey] || attachKey, attachDesc: attachDesc[attachKey] || "",
    attachScore,
    defense: defenseKey, defenseDesc: defenseDesc[defenseKey] || "",
    cockpitStatus, cockpitScore, cockpitDesc: cockpitDesc[cockpitStatus],
    intensity,
    observationPoint: observationMap[mainOSKey] || "",
    nextStep: nextStepMap[mainOSKey] || "",
  };
}

// ─── APP ───
export default function App() {
  const [phase, setPhase]     = useState("intro");
  const [current, setCurrent] = useState(0);
  const [answers, setAnswers] = useState([]);
  const [selected, setSelected] = useState(null);
  const [animating, setAnimating] = useState(false);
  const [result, setResult]   = useState(null);
  const [revealed, setRevealed] = useState(0);

  useEffect(() => {
    if (phase === "result" && revealed < 6) {
      const t = setTimeout(() => setRevealed(r => r + 1), 380);
      return () => clearTimeout(t);
    }
  }, [phase, revealed]);

  useParticles(phase);

  const progress = Math.round((answers.length / QUESTIONS.length) * 100);

  const handleChoice = (choice) => {
    if (animating) return;
    setSelected(choice);
    setAnimating(true);
    setTimeout(() => {
      const newAnswers = [...answers, { q: QUESTIONS[current], choice }];
      setAnswers(newAnswers);
      setSelected(null);
      setAnimating(false);
      if (current + 1 < QUESTIONS.length) {
        setCurrent(c => c + 1);
      } else {
        const validAnswers = newAnswers.filter(a => !a.choice.skipped);
        setResult(calcResult(validAnswers.length > 0 ? validAnswers : newAnswers));
        setPhase("result");
      }
    }, 280);
  };

  const goBack = () => {
    if (current === 0 || animating) return;
    setAnswers(a => a.slice(0, -1));
    setCurrent(c => c - 1);
    setSelected(null);
  };

  const reset = () => {
    setPhase("intro"); setCurrent(0); setAnswers([]);
    setSelected(null); setAnimating(false); setResult(null); setRevealed(0);
  };

  return (
    <div style={S.root}>
      <style>{css}</style>

      {/* HEADER */}
      <div style={S.header}>
        <div>
          <div style={S.logo}>CRONA'LIA</div>
          {phase === "quiz" && <div style={S.logoSub}>{QUESTIONS[current].category}</div>}
        </div>
        {phase === "quiz" && (
          <div style={S.progressWrap}>
            <div style={S.progressBar}>
              <div style={{ ...S.progressFill, width: `${progress}%` }} className="pfill" />
            </div>
            <span style={S.progressNum}>{answers.length} / {QUESTIONS.length}</span>
          </div>
        )}
      </div>

      {/* INTRO */}
      {phase === "intro" && (
        <div style={S.introOuter}>
          <div style={S.introBg} />
          <div style={S.introOverlay} />
          <div style={S.introContent}>
            <div style={S.glyphLg} className="glow">◈</div>
            <h1 style={S.introTitle}>あなたのパターンを、見てみましょう。</h1>
            <p style={S.introDesc}>感情の診断ではありません。<br />思考のクセや行動のパターンを「構造」として見るツールです。</p>
            <div style={S.metaRow}>
              <span style={S.meta}>12の質問</span>
              <span style={S.metaDot}>·</span>
              <span style={S.meta}>タップするだけ</span>
              <span style={S.metaDot}>·</span>
              <span style={S.meta}>約3分</span>
            </div>
            <div style={S.videoRow}>
              <video
                src="data:video/mp4;base64,"
                style={{width:"100%",borderRadius:"8px",objectFit:"cover"}}
                autoPlay muted loop playsInline
              />
              <video
                src="data:video/mp4;base64,"
                style={{width:"100%",borderRadius:"8px",objectFit:"cover"}}
                autoPlay muted loop playsInline
              />
            </div>
            <button style={S.ctaBtn} className="cta" onClick={() => setPhase("quiz")}>はじめる</button>
          </div>
          <canvas id="particles" style={{position:"absolute",inset:0,zIndex:1,pointerEvents:"none"}} />
        </div>
      )}

      {/* QUIZ */}
      {phase === "quiz" && (
        <div style={S.quizWrap}>
          <div style={S.cityBg} />
          <div style={S.qNum}>Q {current + 1}</div>
          <h2 style={S.qText}>{QUESTIONS[current].text}</h2>

          {/* 戻るボタン */}
          <button
            style={{ ...S.backBtn, opacity: current > 0 ? 0.6 : 0, pointerEvents: current > 0 ? "auto" : "none" }}
            className="back-btn"
            onClick={goBack}
          >
            ← 前の質問に戻る
          </button>

          <div style={S.choices}>
            {QUESTIONS[current].choices.map((choice, i) => (
              <button
                key={i}
                style={{ ...S.choiceBtn, ...(selected === choice ? S.choiceSelected : {}) }}
                className="choice-btn"
                onClick={() => handleChoice(choice)}
                disabled={animating}
              >
                {choice.label}
              </button>
            ))}
          </div>

          {/* スキップ */}
          <button
            style={S.skipBtn}
            className="skip-btn"
            onClick={() => handleChoice({ os: null, attachment: null, defense: null, skipped: true })}
            disabled={animating}
          >
            わからない・スキップする
          </button>
        </div>
      )}

      {/* RESULT */}
      {phase === "result" && result && (
        <div style={S.resultWrap}>
          <div style={S.cityBg} />

          {/* タイトル */}
          <div style={revealStyle(revealed, 1)}>
            <div style={S.glyphMd} className="glow">◈</div>
            <h2 style={S.resultTitle}>あなたの構造</h2>
            <p style={S.resultSub}>Structure Report</p>
          </div>

          {/* 構造マップ */}
          <div style={revealStyle(revealed, 2)}>
            <div style={S.mapCard}>
              <div style={S.mapCardTitle}>▸ 構造マップ</div>

              {/* 3ノード */}
              <div style={S.mapRow}>
                {/* 思考OS */}
                <div style={S.mapNode}>
                  <div style={S.nodeTag}>思考OS</div>
                  <div style={S.nodeVal}>{result.mainOS}</div>
                  {result.subOS && <div style={S.nodeSub}>＋{result.subOS}</div>}
                  <div style={S.nodeDesc}>{result.mainOSDesc}</div>
                </div>

                <div style={S.arrow}>→</div>

                {/* 判断軸 */}
                <div style={S.mapNode}>
                  <div style={S.nodeTag}>判断軸</div>
                  <div style={{ ...S.nodeVal, color: result.cockpitScore >= 70 ? "#a8d8a8" : result.cockpitScore >= 45 ? "#c9b99a" : "#d8907a" }}>
                    {result.cockpitStatus}
                  </div>
                  <div style={S.nodeDesc}>{result.cockpitDesc}</div>
                </div>

                <div style={S.arrow}>→</div>

                {/* 愛着スタイル */}
                <div style={S.mapNode}>
                  <div style={S.nodeTag}>愛着スタイル</div>
                  <div style={S.nodeVal}>{result.attachType}</div>
                  <div style={S.nodeDesc}>{result.attachDesc}</div>
                </div>
              </div>

              {/* バー */}
              <div style={S.barsWrap}>
                {[
                  { label: "判断軸の安定度",   val: result.cockpitScore },
                  { label: "愛着の安定度",     val: result.attachScore },
                  { label: "パターンの一貫性", val: result.intensity },
                ].map(b => (
                  <div key={b.label} style={S.barRow}>
                    <div style={S.barLabel}>{b.label}</div>
                    <div style={S.barTrack}>
                      <div style={{
                        ...S.barFill,
                        width: `${b.val}%`,
                        background: b.val >= 70
                          ? "linear-gradient(90deg,#4a7a6a,#a8d8a8)"
                          : b.val >= 45
                          ? "linear-gradient(90deg,#6b5d4f,#c9b99a)"
                          : "linear-gradient(90deg,#7a4a4a,#d8907a)",
                      }} className="pfill" />
                    </div>
                    <div style={S.barNum}>{b.val}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* 防衛パターン */}
          <div style={revealStyle(revealed, 3)}>
            <div style={S.card}>
              <div style={S.cardTag}>よく使われる防衛パターン</div>
              <div style={S.cardMain}>{result.defense}</div>
              <div style={S.cardSub}>{result.defenseDesc}</div>
            </div>
          </div>

          {/* フィードバック */}
          <div style={revealStyle(revealed, 4)}>
            <div style={{ ...S.card, ...S.cardGold }}>
              <div style={{ ...S.cardTag, color: "rgba(201,185,154,0.6)" }}>構造からのフィードバック</div>
              <div style={S.observation}>{result.observationPoint}</div>
            </div>
          </div>

          {/* ヒント */}
          <div style={revealStyle(revealed, 5)}>
            <div style={{ ...S.card, borderColor: "rgba(168,216,168,0.15)" }}>
              <div style={{ ...S.cardTag, color: "rgba(168,216,168,0.5)" }}>ずらすためのヒント</div>
              <div style={{ ...S.cardSub, color: "rgba(168,216,168,0.75)" }}>{result.nextStep}</div>
            </div>
          </div>

          {/* リセット */}
          <div style={revealStyle(revealed, 6)}>
            <button style={S.resetBtn} className="reset-btn" onClick={reset}>もう一度やってみる</button>
          </div>

        </div>
      )}
    </div>
  );
}

const revealStyle = (revealed, step) => ({
  opacity: revealed >= step ? 1 : 0,
  transform: revealed >= step ? "translateY(0)" : "translateY(14px)",
  transition: "opacity 0.5s ease, transform 0.5s ease",
});

